<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Digital Brain") }}</title>
  <meta name="description" content="{{ description | default('A personal knowledge base, digital garden, and blog.') }}">

  <!-- Performance: preconnect to CDNs used for fonts and mermaid -->
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
  <link rel="dns-prefetch" href="https://cdn.jsdelivr.net">

  <!-- Single unified stylesheet -->
  <link rel="stylesheet" href="{{ '/overrides/assets/stylesheets/extra.css' | url }}">
</head>
<body data-md-color-scheme="default">

  <header class="site-header">
    <div class="logo"><strong>Digital Brain</strong></div>
    
    <!-- Pagefind Search UI will mount here -->
    <div id="search" class="search-ui"></div>
        <button id="nav-toggle" class="nav-toggle">☰ Menu</button>
      <button id="theme-toggle" class="theme-toggle">Toggle Dark Mode</button>
  </header>

  <div class="site-layout">
    <!-- Left Navigation (15%) -->
    <nav class="site-nav">
      <h3>Navigation</h3>
      
      {% macro renderNode(node, currentUrl) %}
        {% if node.type == "folder" and node.name != "root" %}
          <details class="nav-folder">
            <summary class="nav-summary">{{ node.name }}</summary>
            <div class="nav-list">
              {% for child in node.childrenArray %}
                {{ renderNode(child, currentUrl) }}
              {% endfor %}
            </div>
          </details>
        {% elif node.type == "folder" and node.name == "root" %}
          {% for child in node.childrenArray %}
            {{ renderNode(child, currentUrl) }}
          {% endfor %}
        {% elif node.type == "file" %}
          <div class="nav-item {% if currentUrl == node.url %}nav-item-active{% endif %}">
            <a href="{{ node.url | url }}">{{ node.title }}</a>
          </div>
        {% endif %}
      {% endmacro %}
      
      {{ renderNode(collections.folderTree, page.url) }}
    </nav>
    
    <!-- Main Content (75%) -->
    <main class="site-content" data-pagefind-body>
      <article class="md-typeset">
        {{ content | safe }}
      </article>
      
      <hr>

      <!-- Backlinks injected by Eleventy collection -->
      {% if collections.backlinks[page.url] and collections.backlinks[page.url].length > 0 %}
      <section class="backlinks">
        <h3>Backlinks</h3>
        <ul>
        {% for link in collections.backlinks[page.url] %}
          <li><a href="{{ link.url | url }}">{{ link.title }}</a></li>
        {% endfor %}
        </ul>
      </section>
      {% endif %}
    </main>

    <!-- Right TOC (10%) -->
    <aside class="site-toc" id="toc-container">
      <h3>Table of Contents</h3>
      <!-- JavaScript will populate this based on h2/h3 tags -->
    </aside>
  </div>

  <!-- Pagefind Script (loaded after content paints) -->
  <link href="{{ '/pagefind/pagefind-ui.css' | url }}" rel="stylesheet" media="print" onload="this.media='all'">
  <script defer src="{{ '/pagefind/pagefind-ui.js' | url }}"></script>
  <script>
    window.addEventListener('DOMContentLoaded', (event) => {
      try {
        if (typeof PagefindUI !== 'undefined') {
          new PagefindUI({ element: "#search", showSubResults: true });
        }
      } catch(e) {
        console.log("Pagefind UI not loaded locally");
      }
    });
  </script>

  <!-- Client-side TOC Generator & Scroll Spy -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const tocContainer = document.getElementById('toc-container');
      const headings = document.querySelectorAll('.site-content article h2, .site-content article h3');
      const tocLinks = [];
      
      if (headings.length > 0) {
        const ul = document.createElement('ul');
        ul.style.listStyle = 'none';
        ul.style.paddingLeft = '0';
        
        headings.forEach(h => {
          const li = document.createElement('li');
          const a = document.createElement('a');
          
          if (!h.id) {
            h.id = h.innerText.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
          }
          
          a.href = '#' + h.id;
          a.innerText = h.innerText;
          
          if (h.tagName.toLowerCase() === 'h3') {
            li.style.paddingLeft = '1rem';
          }
          
          li.style.marginBottom = '0.2rem';
          li.appendChild(a);
          ul.appendChild(li);
          tocLinks.push({ id: h.id, link: a });
        });
        
        tocContainer.appendChild(ul);

        // Scroll Spy Intersection Observer
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // Remove active from all
              tocLinks.forEach(item => item.link.classList.remove('active'));
              // Find corresponding link and make active
              const activeItem = tocLinks.find(item => item.id === entry.target.id);
              if (activeItem) {
                activeItem.link.classList.add('active');
              }
            }
          });
        }, { rootMargin: "0px 0px -80% 0px", threshold: 0.1 }); // Trigger when heading passes top 20%
        
        headings.forEach(h => observer.observe(h));
      }
    });
  </script>

  <!-- Theme & Nav Toggle -->
  <script>
    const themeToggle = document.getElementById('theme-toggle');
    const navToggle   = document.getElementById('nav-toggle');

    // Restore saved theme
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) {
      document.body.setAttribute('data-md-color-scheme', savedTheme);
    }

    themeToggle.addEventListener('click', () => {
      const currentTheme = document.body.getAttribute('data-md-color-scheme') || 'default';
      const newTheme = currentTheme === 'default' ? 'slate' : 'default';
      document.body.setAttribute('data-md-color-scheme', newTheme);
      localStorage.setItem('theme', newTheme);
    });

    navToggle.addEventListener('click', () => {
      document.body.classList.toggle('nav-open');
    });
  </script>

  <!-- Legacy Scripts -->
  <script defer src="{{ '/overrides/assets/javascripts/backlinks.js' | url }}"></script>

  <!-- Mermaid.js for Diagrams -->
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';
    
    document.addEventListener("DOMContentLoaded", () => {
      const isDarkMode = document.body.getAttribute('data-md-color-scheme') === 'slate';
      mermaid.initialize({ 
        startOnLoad: false, 
        theme: isDarkMode ? 'dark' : 'default',
        securityLevel: 'loose'
      });
      
      // Convert markdown-it <code class="language-mermaid"> to <div class="mermaid">
      const mermaidBlocks = document.querySelectorAll('code.language-mermaid');
      mermaidBlocks.forEach(el => {
        const pre = el.parentElement;
        if (pre && pre.tagName === 'PRE') {
          const div = document.createElement('div');
          div.className = 'mermaid';
          div.textContent = el.textContent;
          pre.parentElement.replaceChild(div, pre);
        }
      });
      
      // Run mermaid on all elements with class 'mermaid'
      mermaid.run({ querySelector: '.mermaid' }).catch(err => console.error(err));
    });
  </script>
</body>
</html>
